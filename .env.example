# AhaSend transactional email (contact form) — API v2.
# Copy to .env.local for local dev; set the same vars in cPanel →
# Setup Node.js App → Environment variables (then restart the app).

# API key from AhaSend (Account → API keys). Needs the "messages:send:<domain>"
# scope (or messages:send:all). Looks like: aha-sk-...
AHASEND_API_KEY=

# Your AhaSend Account ID (used in the API path).
AHASEND_ACCOUNT_ID=

# Address messages are sent FROM — must be on a domain verified in AhaSend.
CONTACT_FROM_EMAIL=

# Inbox where contact-form submissions are delivered.
CONTACT_TO_EMAIL=
